generator client {
  provider               = "prisma-client"
  output                 = "lib/prisma_generated"
  generatedFileExtension = "ts"
  importFileExtension    = "ts"
  moduleFormat           = "esm"
  runtime                = "nodejs"
}

datasource db {
  provider = "sqlite"
}

model Actor {
  id                       String  @id
  owner                    String
  level                    Int
  name                     String
  alias                    String
  avatar_url               String
  abilities                Json
  proficiencies            Json
  flags_hasjackofalltrades Boolean @default(false)
}
